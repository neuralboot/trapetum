# compiled binaries / objects
*.o
*.out
*.exe
.DS_Store
*.swp
# compiled executables built from the .cu sources (no extension)
bench
gemv
gemv4
prof
p[0-9]*
prof[0-9]*
# never ignore source files
!*.cu
# the line "bench" above is the compiled executable of bench.cu; keep the bench/ dir
!bench/

# local submission helpers (endorsement code, arXiv form text, X thread draft)
paper/*.txt
paper/*.tex
__pycache__/
*.pyc

# compressed drafter/target model blobs (large)
drafters/**/*.cbk
drafters/**/*.bin

# stray working reports / drafts (never part of the repo)
/EXPERT_ULTRATHINK_PROJECT_VERIFICATION_REPORT.txt
/RESPONSE_TO_REVIEW.txt
/lossless_report*.html
/model/modeling_deepseek_reference.py
# latex build artifacts
paper/*.aux
paper/*.log
paper/*.out
# local cpu microbench binaries + sources
bench/cpu_codebook_neon
bench/cpu_codebook_neon_v2
